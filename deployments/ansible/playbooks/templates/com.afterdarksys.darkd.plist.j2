<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.afterdarksys.darkd</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/afterdark-darkd</string>
        <string>--config</string>
        <string>{{ afterdark_config_dir }}/darkd.yaml</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>{{ afterdark_data_dir }}</string>

    <key>StandardOutPath</key>
    <string>{{ afterdark_log_dir }}/darkd.log</string>

    <key>StandardErrorPath</key>
    <string>{{ afterdark_log_dir }}/darkd.error.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>DARKAPI_API_KEY</key>
        <string>{{ darkapi_key }}</string>
    </dict>
</dict>
</plist>
